rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // LAYER 1 — GLOBAL PLATFORM COLLECTIONS
    // NO client reads or writes. Service accounts only (via Admin SDK).
    // ================================================================

    match /master_contacts/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /master_accounts/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /master_households/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /master_leads/{id} {
      // Clients may read master_lead docs referenced by their assignments
      allow read: if request.auth != null;
      allow write: if false;  // writes: service account only
    }
    match /lead_assignments/{id} {
      // Advisors can read and update ONLY their own assignments.
      // Operator (kosal@fin-tegration.com) can read all.
      // create/delete still locked to service accounts.
      allow read:   if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                        || request.auth.token.email == 'kosal@fin-tegration.com');
      allow update: if request.auth != null && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['advisorStatus', 'advisorFeedback', 'advisorFeedbackNotes',
                                   'feedbackAt', 'updatedAt']);
      allow create, delete: if false;  // service account only
    }
    match /routing_queue/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /routing_logs/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /governance_flags/{id} {
      // Operator can read all flags surfaced by runGovernance.
      // Operator can also write resolvedAt/resolvedBy/resolution (P1 — Mark Resolved).
      // All other field writes and creates are service-account-only.
      allow read:   if request.auth != null
                   && request.auth.token.email == 'kosal@fin-tegration.com';
      // update: operator only, restricted to resolution fields
      allow update: if request.auth != null
                   && request.auth.token.email == 'kosal@fin-tegration.com'
                   && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['resolvedAt', 'resolvedBy', 'resolution', 'resolvedByUid']);
      allow create, delete: if false;  // service account only
    }
    match /routing_policies/{id} {
      // Operator can read (inspect/verify weights); writes are service-account-only
      allow read:  if request.auth != null
                   && request.auth.token.email == 'kosal@fin-tegration.com';
      allow write: if false;
    }
    match /suppression_registry/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /manual_review_queue/{id} {
      allow read: if false;
      allow write: if false;
    }

    // ================================================================
    // LAYER 3 — ADVISOR WORKSPACE
    // Authenticated users can only read/write their own documents.
    // ================================================================

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ================================================================
    // OUTREACH OUTCOMES (Phase C1 — Measurement)
    // Advisors can create and read their own outcome events.
    // advisorUid on the document must match the authenticated user.
    // ================================================================
    match /outreach_outcomes/{docId} {
      // Create: anyone auth'd, but advisorUid must equal their UID
      allow create: if request.auth != null
                    && request.resource.data.advisorUid == request.auth.uid;
      // Read own outcomes only
      allow read:   if request.auth != null
                    && resource.data.advisorUid == request.auth.uid;
      // Update own outcomes (for reply classification write-back)
      allow update: if request.auth != null
                    && resource.data.advisorUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['outcome', 'replyClassification', 'replyLoggedAt']);
      allow delete: if false;
    }

    // ================================================================
    // OPERATOR PRESENCE (Phase C1 — Admin Dashboard)
    // Each advisor writes their own presence doc.
    // Only the operator email can read the full collection.
    // ================================================================
    match /operator_presence/{uid} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read:  if request.auth != null
                   && request.auth.token.email == 'kosal@fin-tegration.com';
    }

    // ================================================================
    // ADVISOR POOL (routing engine eligibility)
    // Each advisor writes their own doc; operator can read all.
    // ================================================================
    match /advisor_pool/{uid} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read:  if request.auth != null
                   && (request.auth.uid == uid
                       || request.auth.token.email == 'kosal@fin-tegration.com');
    }

    // ================================================================
    // ADVISOR SETTINGS — booking link, preferences, cross-device sync
    // Each advisor reads and writes only their own doc.
    // ================================================================
    match /advisor_settings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ================================================================
    // PROSPECTS (Alfred-imported shared pool)
    // Any authenticated advisor can read.
    // Writes only from Admin SDK (import script) — not from browser.
    // ================================================================
    match /prospects/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;   // Admin SDK only (bypasses rules)
    }

    // ================================================================
    // CLIENT INTELLIGENCE — ED / Al Collections
    // Merged from EdAlTim — 2026-04-08 per Vera compliance plan
    //
    // PHASE 1 (PILOT): All writes require request.auth != null.
    // Ed intake is advisor-entered from the authenticated cockpit only.
    // Public client-facing intake requires a Cloud Function gateway
    // before enabling unauthenticated writes — see VERA_HANDOFF Phase 2.
    // ================================================================

    // isOperator() — reusable helper (email matches operator account)
    function isOperator() {
      return request.auth != null
          && request.auth.token.email == 'kosal@fin-tegration.com';
    }

    // ED CONSENT LOG — write-once audit trail
    // Phase 1: Only authenticated users (advisor or operator) can create.
    // Phase 2: Move to Cloud Function gateway for public intake.
    match /ed_consent_log/{docId} {
      allow create: if request.auth != null;
      // Never allow update or delete — immutable audit record
      allow update, delete: if false;
      // Operator reads all; referring advisor reads their own
      allow read: if isOperator()
               || (request.auth != null
                   && request.auth.uid == resource.data.referringAdvisorUid);
    }

    // ED SITUATIONS — scoped to referringAdvisorUid or assignedAdvisorUid
    // Phase 1: Authenticated write only (advisor enters on behalf of client).
    // Phase 2: Cloud Function gateway accepts public POST, writes via Admin SDK.
    match /ed_situations/{docId} {
      allow create: if request.auth != null;
      // Read: assigned advisor or operator only
      allow read: if isOperator()
               || (request.auth != null
                   && (request.auth.uid == resource.data.referringAdvisorUid
                    || request.auth.uid == resource.data.assignedAdvisorUid));
      // Status updates: assigned advisor only, restricted fields
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.assignedAdvisorUid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'assignedAdvisorUid', 'statusUpdatedAt']);
      allow delete: if false;
    }

    // AL ASSIGNMENTS — Sprint 4: FROZEN ARCHIVE. Read-only. No new writes from the browser.
    // All 30 docs were migrated to lead_assignments in Sprint 4.
    // create: if false  — new assignments go to lead_assignments only
    // update: if false  — all status updates now target lead_assignments
    // delete: if false  — archive preserved for audit
    match /al_assignments/{docId} {
      allow create: if false;  // P4: frozen — Sprint 4 migration complete
      allow read: if isOperator()
               || (request.auth != null
                   && request.auth.uid == resource.data.advisorUid);
      allow update: if false;  // P4: frozen — all write-backs now go to lead_assignments
      allow delete: if false;
    }

    // ================================================================
    // FUNNEL EVENTS (Phase C3 — Advisor Journey Tracking)
    // Advisors fire-and-forget their own events; operator reads all.
    // advisorUid on the document must match the authenticated user.
    // ================================================================
    match /funnel_events/{docId} {
      // Create: auth'd advisor only; advisorUid must equal their own UID
      allow create: if request.auth != null
                    && request.resource.data.advisorUid == request.auth.uid;
      // Read: operator reads all (for Admin Dashboard 30-day funnel)
      //       advisor reads their own (for My Activity widget)
      allow read:   if isOperator()
                 || (request.auth != null
                     && resource.data.advisorUid == request.auth.uid);
      // Never allow update or delete — immutable event log
      allow update, delete: if false;
    }

    // ================================================================
    // SECURITY SENTINEL — sentinel_* collections (Sprint 1)
    // Read-only from client. Writes are Admin SDK only.
    // sentinel_config / sentinel_orgs: operator + any authenticated user
    //   (needed so loadSentinelConfig() can check the feature flag on login)
    // All other sentinel_* collections: any authenticated user
    //   (org_id is the logical scope; tighter per-advisor rules in Sprint 2)
    // ================================================================

    match /sentinel_config/{docId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK only
    }
    match /sentinel_orgs/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /sentinel_assets/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /sentinel_findings/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /sentinel_tasks/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /sentinel_runs/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
    match /sentinel_reports/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ================================================================
    // DENY ALL — catch-all for any unmatched paths
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
